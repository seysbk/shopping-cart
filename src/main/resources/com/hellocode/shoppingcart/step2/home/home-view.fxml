<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>
<VBox prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml"
    fx:controller="com.hellocode.shoppingcart.step2.home.HomeController"
    style="-fx-background-color: transparent;">
    <padding>
        <Insets top="24" right="24" bottom="24" left="24" />
    </padding>
    <children>
        <Label text="Coders Collection" style="-fx-font-family: 'Segoe Script'; -fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #111827;" />
        <Label fx:id="statusLabel" text="" style="-fx-font-size: 14px; -fx-text-fill: #2563eb; -fx-padding: 0 0 8 0;" />
        <GridPane fx:id="productGridPane" hgap="16" vgap="16" />
    </children>
</VBox>
